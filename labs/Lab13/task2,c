#include <stdio.h>
#include <stdlib.h>

int main() {
    int n;

    printf("Введите число: ");
    scanf("%d", &n);

    if (n > 0) {
        printf("Положительное число\n");
        exit(1);
    }
    else if (n < 0) {
        printf("Отрицательное число\n");
        exit(-1);
    }
    else {
        printf("Ноль\n");
        exit(0);
    }
}
